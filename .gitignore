# System & Python Ignore Rules
.DS_Store
.AppleDouble
.LSOverride
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
*.egg-info/
.installed.cfg
*.egg

# Global Secrets & Configuration (Recursive)
# These files are ignored in EVERY directory to protect all environments
auth.json
config.yaml
certs/
backup/
backups/
logs/

# Build Artifacts
*.tar
*.zip
*.gz
*.log
code_backup/

# Release Specific
prod/app/
dist/LINKEDIN_DRAFT.md
dist/assets/images/*.png

# Internal Documentation & Drafts
documentation/product_vision.md
documentation/project_standards.md
implementation_plan*.md
REDDIT_*.md
LINKEDIN_*.md
GITHUB_RELEASE*.md
documentation/ROADMAP.md

# Local Debug, Logs & Backups (Recursive)
*.bak
*.broken*
debug_*.py
server_debug.log
server_output*.log
cert_automate.log
input_certificates/
version_info.json
!build_scripts/version_info.json
